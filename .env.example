# --- SUPABASE LOCAL SETTINGS ---
# Get these values by running 'npx supabase status' after 'npx supabase start'

# The base URL of your local Supabase stack
SUPABASE_URL=http://localhost:54321

# The Public Anon Key (for public access / frontend)
SUPABASE_KEY=your_anon_key_here

# The Service Role Key (for administrative scripts / bypass RLS)
# WARNING: Never use this in the frontend!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- DATABASE SETTINGS ---
# Local Postgres connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- TEST USER CREDENTIALS ---
# Used by Python scripts to authenticate
SUPABASE_USER_EMAIL=admin@example.com
SUPABASE_USER_PASSWORD=password123
